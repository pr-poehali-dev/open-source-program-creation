{
  "tests": [
    {
      "name": "Статус ИИ-ассистента",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200,
      "expectedBody": "active",
      "bodyMatcher": "contains"
    },
    {
      "name": "Диалог с ИИ",
      "method": "POST",
      "path": "/",
      "body": {"message": "Привет", "session_id": "test-001", "history": []},
      "expectedStatus": 200,
      "expectedBody": "reply",
      "bodyMatcher": "contains"
    },
    {
      "name": "Диалог с контекстом ЦПВОА",
      "method": "POST",
      "path": "/",
      "body": {
        "message": "Анализ",
        "session_id": "test-cpvoa",
        "history": [],
        "cpvoa_context": {"incidents": [], "sensors": {}, "connection": "online", "mode": "advanced"}
      },
      "expectedStatus": 200,
      "expectedBody": "reply",
      "bodyMatcher": "contains"
    }
  ]
}